{
  "name": "smart-vpn",
  "version": "1.0.0",
  "description": "Умный VPN-сервис с Xray VLESS, Telegram-ботом и AI-ориентированным CI/CD",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "node src/database/seed.js",
    "backup": "node src/utils/backup.js",
    "ci:test": "jest --ci --coverage --reporters=default --reporters=jest-junit"
  },
  "keywords": [
    "vpn",
    "xray",
    "vless",
    "telegram-bot",
    "smart-vpn"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "telegraf": "^4.15.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "pg": "^8.11.3",
    "sequelize": "^6.35.0",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-validator": "^7.0.1",
    "node-cron": "^3.0.3",
    "ioredis": "^5.3.2",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.1",
    "qrcode": "^1.5.3",
    "stripe": "^14.9.0",
    "nodemailer": "^6.9.7",
    "handlebars": "^4.7.8",
    "express-session": "^1.17.3",
    "connect-redis": "^7.1.1",
    "multer": "^1.4.5-lts.1",
    "compression": "^1.7.4",
    "http-proxy-middleware": "^2.0.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "jest-junit": "^16.0.0",
    "docker-compose": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
